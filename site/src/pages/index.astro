---
import Base from '../layouts/Base.astro';
import NewsSheet from '../components/NewsSheet.astro';
import WeekNav from '../components/WeekNav.astro';
import { loadNews, latestCycle } from '../lib/data.js';

const news = loadNews();
const latest = news.at(-1);
const max = latestCycle();
---

<Base title="오늘의 소식" active="news">
  <p class="kicker">이번 주의 지면</p>
  <WeekNav current={latest?.cycle} max={max} />
  {latest ? <NewsSheet issue={latest} /> : <p>아직 발행된 소식지가 없다.</p>}
</Base>
